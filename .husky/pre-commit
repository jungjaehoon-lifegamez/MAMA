#!/bin/sh
set -e

# PII check: scan staged files for personal/project information
# Patterns loaded from .pii-patterns (gitignored, local only)
if [ -f scripts/check-pii.sh ]; then
  bash scripts/check-pii.sh
fi

# Korean hardcoding check: block non-functional Korean in source files
# Allows: regex patterns, string literals in keyword arrays, meta[] lookups, Unicode ranges
if git diff --cached --name-only | grep -qE '\.tsx?$'; then
  KOREAN_IN_SOURCE=$(git diff --cached -U0 -- '*.ts' '*.tsx' | grep '^+' | grep -v '^+++' | \
    grep '[가-힣]' | \
    grep -v -E '(/(가-힣|[가-힣])/|/[^/]*\\\\[가-힣]|meta\[|RegExp|new Set|Keywords|keywords|Patterns|patterns|IGNORE_PATTERNS|INCOMPLETE_PATTERNS|COMPLETION_MARKERS|가-힣_|// Korean:|includes\(|lowerContent\.|\.match\(|\.includes\()' || true)
  if [ -n "$KOREAN_IN_SOURCE" ]; then
    echo "❌ Korean text detected in staged .ts files:"
    echo "$KOREAN_IN_SOURCE"
    echo ""
    echo "Source code must be in English. Korean is only allowed in:"
    echo "  - Regex patterns for Korean input detection"
    echo "  - Keyword arrays for Korean user matching"
    echo "  - meta[] lookups for Korean spreadsheet data"
    exit 1
  fi
fi

# Run lint-staged for staged files (ESLint + Prettier)
npx lint-staged

# Secret scanning with gitleaks
echo "Scanning for secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner
else
  # Check if gitleaks is available via npx
  if npx --yes gitleaks --version >/dev/null 2>&1; then
    # gitleaks available - run scan (will exit non-zero if secrets found)
    npx --yes gitleaks protect --staged --no-banner
  else
    echo "⚠️  gitleaks not installed, skipping secret scan"
  fi
fi

# Sync doc versions with package.json (auto-stage if changed)
node scripts/sync-versions.js
git diff --quiet -- README.md docs/ || git add README.md docs/guides/deployment.md docs/architecture/package-structure.md 2>/dev/null

# Run typecheck for standalone package
echo "Running typecheck..."
pnpm --filter @jungjaehoon/mama-os typecheck || pnpm --filter @jungjaehoon/mama-standalone typecheck

# Run tests for changed packages only (faster commits)
# Uses turbo for caching benefits
echo "Running tests for changed packages..."
CI=true pnpm turbo run test --filter="...[HEAD^1]" --cache-dir=.turbo 2>&1 || CI=true pnpm test
